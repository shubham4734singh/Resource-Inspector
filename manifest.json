{
  "manifest_version": 3,
  "name": "Resource Inspector",
  "description": "Detect downloadable resources already loaded during a browser session.",
  "version": "0.1.0",
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_title": "Resource Inspector",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "background": {
    "service_worker": "extension/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extension/content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": ["<all_urls>"]
}
